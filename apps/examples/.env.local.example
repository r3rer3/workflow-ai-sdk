# Copy this file to .env.local and fill in the values you need.
# Every variable is optional; routes either return a clear 503 or fall back to
# offline-safe defaults when the matching env is absent.

# OpenAI key — required for the basic chat route, and used by the tool-response,
# agent-handoff, and parallel-research routes when you want real model-driven
# behavior. Without this, /api/chat returns 503 and the other example routes
# fall back to deterministic offline behavior where available.
OPENAI_API_KEY=

# Supabase example (/api/db + /api/auth).
#
# Use a Supabase project's URL and publishable key. DO NOT use the secret key.
# The /api/db route verifies the caller with supabase.auth.getUser() and
# relies on Row Level Security policies defined in apps/examples/supabase/
# schema.sql to scope all reads/writes to auth.uid().
#
# To exercise the flow end-to-end:
#   1. Apply apps/examples/supabase/schema.sql to your project.
#   2. Create a user via Supabase Studio or your own signup flow.
#   3. Go to /db in the browser, or follow steps 4-5 to use curl
#   4. Sign in via POST /api/auth with a cookie jar:
#        curl -c cookies.txt -X POST http://localhost:3000/api/auth \
#          -H 'content-type: application/json' \
#          -d '{"email":"demo@example.com","password":"..."}'
#   5. Drive /api/db with the cookie jar:
#        curl -b cookies.txt -X POST http://localhost:3000/api/db \
#          -H 'content-type: application/json' \
#          -d '{"action":"start","topic":"persisted-run"}'
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
